export PATH=$PATH:$HOME/.local/bin

# Initialize completion system first
autoload -Uz compinit
compinit

# Configure completion system
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
zstyle ':completion:*' group-name ''
zstyle ':completion:*:descriptions' format '%B%d%b'
zstyle ':completion:*' completer _complete _match _approximate
zstyle ':completion:*:match:*' original only
zstyle ':completion:*:approximate:*' max-errors 1 numeric

# Enable completion caching
zstyle ':completion:*' use-cache yes
zstyle ':completion:*' cache-path ~/.zsh/cache

# Add cargo to PATH for Sheldon
export PATH="$HOME/.cargo/bin:$PATH"

# Bottom-up prompt setup
# Add some space to push prompt towards bottom
export PROMPT_EOL_MARK=""

# Function to add padding and keep prompt at bottom
bottom_up_padding() {
    local terminal_height=$(tput lines)
    local content_height=10  # Adjust based on your preference
    local padding=$((terminal_height - content_height))

    if [ $padding -gt 0 ]; then
        printf '\n%.0s' $(seq 1 $padding)
    fi
}

# Alternative: Manual bottom-up command
alias bottom='clear; printf "\n%.0s" $(seq 1 $(($(tput lines) - 5)))'

# Function to start a bottom-up session
start_bottom_up() {
    clear
    printf '\n%.0s' $(seq 1 $(($(tput lines) - 10)))
    echo "🚀 Bottom-up mode activated! Type 'bottom' to reset position."
}

# Split-screen prompt sessions
alias split='split-prompt'
alias sp='split-prompt'
alias asplit='advanced-split'
alias as='advanced-split'

# Modern CLI Tools - Using functions instead of aliases for better completion
ls() { eza --color=always --group-directories-first --icons "$@" }
ll() { eza -l --color=always --group-directories-first --icons "$@" }
la() { eza -la --color=always --group-directories-first --icons "$@" }
lt() { eza -T --color=always --group-directories-first --icons "$@" }
l.() { eza -a "$@" | grep -E "^\." }
find() { fd "$@" }
grep() { rg "$@" }
alias cd='z'  # zoxide smart cd (alias works fine for cd)

# C++ Compiler Default Flags
export CXXFLAGS="-std=c++23 -Wall -Wextra -O2 -g"
export CFLAGS="-Wall -Wextra -O2 -g"
export LDFLAGS=""  # Add linker flags here if needed

# Smart g++ wrapper with sensible defaults
g++() {
    local default_flags="-std=c++23 -Wall -Wextra -Wpedantic -O2 -g"

    # Check if user provided their own flags
    local has_std_flag=false
    local has_optimization=false
    local has_debug=false

    for arg in "$@"; do
        case "$arg" in
            -std=*) has_std_flag=true ;;
            -O*) has_optimization=true ;;
            -g*) has_debug=true ;;
        esac
    done

    # Build final command with smart defaults
    local final_flags=""
    if ! $has_std_flag; then
        final_flags="$final_flags -std=c++23"
    fi
    if ! $has_optimization; then
        final_flags="$final_flags -O2"
    fi
    if ! $has_debug; then
        final_flags="$final_flags -g"
    fi

    # Always add warning flags unless explicitly overridden
    final_flags="$final_flags -Wall -Wextra -Wpedantic"

    echo "🔨 g++ $final_flags $@"
    command g++ $final_flags "$@"
}

# Quick compilation aliases for common patterns
alias g++debug='g++ -std=c++23 -Wall -Wextra -g -O0 -DDEBUG'
alias g++release='g++ -std=c++23 -Wall -Wextra -O3 -DNDEBUG'
alias g++fast='g++ -std=c++23 -O3 -march=native'

# Custom completion will be set up after fzf loads

# Function to run command and display output in top pane
run_split() {
    if [[ -n $TMUX ]]; then
        # Run command and send output to top pane
        eval "$@" | tmux send-keys -t 0 "$(cat)" Enter
    else
        echo "❌ Not in tmux session. Run 'split' first."
    fi
}

# Basic completion setup (bypassing zplug for now)
# Force completion rebuild
autoload -Uz compinit
compinit -f

# Basic autosuggestions and syntax highlighting (if available)
if [[ -f /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]]; then
  source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
fi

if [[ -f /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]]; then
  source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi

# Ensure TAB completion works properly
bindkey '^I' expand-or-complete
bindkey '^[[Z' reverse-menu-complete

# Zoxide - Smart directory jumping
eval "$(zoxide init zsh)"

# Git-extras completions
source /opt/homebrew/opt/git-extras/share/git-extras/git-extras-completion.zsh

# fzf - Fuzzy finder shell integration
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# Starship Prompt
eval "$(starship init zsh)"

# Note: Tab completion shows some extra entries like 'file' command
# This is normal behavior with enhanced completion systems (fzf, zoxide, etc.)
